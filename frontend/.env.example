# ============================================================
# The Invisible Algorithm — Frontend Environment Variables
# ============================================================
# Copy to .env.local for local development.
# Add the same names/values to Vercel Project Settings → Environment
# Variables for production/preview deploys.
# ============================================================

# MongoDB Atlas connection string (Application, Announcement, Event,
# ContactMessage, Newsletter, User, Research collections)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/invisible-algorithm

# JWT secrets — generate with: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Sanity CMS (used for Research content + the /studio editor)
# Project ID and dataset from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_SITE_NAME=The Invisible Algorithm

# Google Drive (stores uploaded research PDFs)
# Uploads authenticate as a real Google account via OAuth2, not a service
# account — service accounts have no storage quota on a personal Gmail
# account, so they can't actually write files into a shared folder there.
#
# Setup: create an OAuth Client ID (Web application) in Google Cloud
# Console, enable the Drive API, add http://localhost:8080/oauth2callback
# as an authorized redirect URI, then run:
#   node --env-file=.env.local scripts/get-drive-token.mjs
# (with GOOGLE_OAUTH_CLIENT_ID/SECRET already set below) to mint the
# refresh token — it writes GOOGLE_OAUTH_REFRESH_TOKEN into .env.local
# for you.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
