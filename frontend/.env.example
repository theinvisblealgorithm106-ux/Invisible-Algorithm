# ============================================================
# The Invisible Algorithm — Frontend Environment Variables
# ============================================================
# Copy to .env.local for local development
# Add these to Vercel project settings for production
# ============================================================

# Backend API URL
# Development: http://localhost:5000/api
# Production: https://your-render-service.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=The Invisible Algorithm
