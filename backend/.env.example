# ============================================================
# The Invisible Algorithm — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Allowed Origins (comma-separated for production)
# Example: https://theinvisiblealgorithm.org,https://www.theinvisiblealgorithm.org
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# MongoDB Atlas
# ============================================================
# Get this from: MongoDB Atlas > Clusters > Connect > Drivers
# Replace <username>, <password>, <cluster> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/invisible-algorithm?retryWrites=true&w=majority

# ============================================================
# JWT Authentication
# ============================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# Email (SMTP)
# ============================================================
# For Gmail: enable 2FA and generate an App Password
# Google Account > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
FROM_EMAIL=noreply@theinvisiblealgorithm.org
FROM_NAME=The Invisible Algorithm

# ============================================================
# Initial Super Admin (created on first startup)
# ============================================================
ADMIN_EMAIL=admin@theinvisiblealgorithm.org
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_12_CHARS
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ============================================================
# Frontend URL (used in email links)
# ============================================================
FRONTEND_URL=http://localhost:3000
